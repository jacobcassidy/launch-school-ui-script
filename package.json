{
  "name": "ls-script-ui",
  "version": "1.0.0",
  "description": "Build tools for LS UI Script",
  "author": {
    "name": "Jacob Cassidy",
    "email": "jacob@jacobcassidy.com",
    "url": "https://jacobcassidy.com"
  },
  "homepage": "https://github.com/jacobcassidy/launch-school-ui-script/blob/main/README.md",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobcassidy/launch-school-ui-script.git"
  },
  "bugs": {
    "url": "https://github.com/jacobcassidy/launch-school-ui-script/issues"
  },
  "devDependencies": {
    "@cassidydc/stylelint-config-w3c-order": "^1.3.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/stylelint-config": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "lefthook": "^2.1.10",
    "markdownlint-cli2": "^0.23.0",
    "prettier-plugin-multiline-arrays": "^4.1.10",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-plugin-logical-css": "^2.1.0"
  },
  "scripts": {
    "check": "npx prettier . --check",
    "format": "npx prettier . --write",
    "lint:docs": "npx markdownlint-cli2 \"**/*.md\"",
    "lint:docs:fix": "npx markdownlint-cli2 \"**/*.md\" --fix",
    "lint:scripts": "npx eslint",
    "lint:scripts:fix": "npx eslint --fix",
    "lint:styles": "npx stylelint \"**/*.css\" --ignore-path .gitignore",
    "lint:styles:fix": "npx stylelint \"**/*.css\" --ignore-path .gitignore --fix",
    "build": "node ./esbuild.config.js",
    "watch": "node ./esbuild.config.js --watch"
  }
}
